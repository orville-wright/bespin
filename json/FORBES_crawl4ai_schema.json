{
  "name": "ForbesNewsSelector",
  "baseSelector": "div[data-module='stream'] div[data-module='stream-item']",
  "fields": [
    {
      "name": "Title",
      "selector": "h3 a",
      "type": "text"
    },
    {
      "name": "Ext_url",
      "selector": "h3 a",
      "type": "attribute",
      "attribute": "href"
    },
    {
      "name": "Author",
      "selector": "div[data-module='byline'] a",
      "type": "text"
    },
    {
      "name": "Time",
      "selector": "time",
      "type": "text"
    }
  ]
}