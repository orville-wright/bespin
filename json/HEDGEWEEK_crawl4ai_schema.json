{
  "name": "HedgeweekNewsSelector",
  "baseSelector": "div.news-item",
  "fields": [
    {
      "name": "Title",
      "selector": "h3 a",
      "type": "text"
    },
    {
      "name": "Ext_url",
      "selector": "h3 a",
      "type": "attribute",
      "attribute": "href"
    },
    {
      "name": "Author",
      "selector": "div.news-meta span.author",
      "type": "text"
    },
    {
      "name": "Time",
      "selector": "div.news-meta span.date",
      "type": "text"
    }
  ]
}