# Use a base image that suits your project's needs (e.g., Python, Node.js)
FROM mcr.microsoft.com/devcontainers/python:3.11-bullseye

# Install PostgreSQL client tools (optional, if you want to interact with PostgreSQL from your app container)
RUN apt-get update && apt-get install -y postgresql-client

# Set up any additional environment variables or configurations for your application
ENV PYTHONUNBUFFERED 1
